{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Swiss Kyle",
  "version": "0.1.0",
  "identifier": "com.swiss.kyle",
  "build": {
    "frontendDist": "../swiss-kyle-ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run prepare-sidecars.ts && cd swiss-kyle-ui && bun install && bun dev",
    "beforeBuildCommand": "bun run prepare-sidecars.ts && cd swiss-kyle-ui && bun install && bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Swiss Kyle",
        "width": 1280,
        "height": 750,
        "resizable": true,
        "fullscreen": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/nats-server",
      "binaries/worker",
      "binaries/ffmpeg",
      "binaries/pandoc",
      "binaries/typst"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
