{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Swiss Kyle",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": "../swiss-kyle-ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "./scripts/prepare-sidecars.sh && cd swiss-kyle-ui && bun dev",
    "beforeBuildCommand": "./scripts/prepare-sidecars.sh && cd swiss-kyle-ui && bun build"
  },
  "app": {
    "windows": [
      {
        "title": "Swiss Kyle",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/nats-server",
      "binaries/worker"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
