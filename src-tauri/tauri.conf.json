{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Swiss Kyle",
  "version": "0.0.7",
  "identifier": "com.swiss.kyle",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run prepare-sidecars.ts && cd ui && bun install && bun dev",
    "beforeBuildCommand": "bun run prepare-sidecars.ts && cd ui && bun install && bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Swiss Kyle",
        "width": 1280,
        "height": 750,
        "resizable": true,
        "fullscreen": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "mainBinaryName": "swiss-kyle",
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "app", "dmg", "nsis"],
    "resources": {
      "binaries/ffmpeg-*": "bin/",
      "binaries/pandoc-*": "bin/",
      "binaries/typst-*": "bin/",
      "binaries/pdfcpu-*": "bin/",
      "binaries/nats-server-*": "bin/",
      "binaries/swiss-kyle-worker-*": "bin/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
