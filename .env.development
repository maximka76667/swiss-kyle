# Loaded by every debug build (never release — see base_output_dir() in
# crates/shared/src/lib.rs) to keep dev/test job output out of the real
# Documents folder. This is a bare folder name, not a path — it always
# nests under <repo root>/.development/, which is gitignored wholesale, so
# this value never needs to be mirrored in .gitignore.
SWISS_KYLE_OUTPUT_DIR=output
